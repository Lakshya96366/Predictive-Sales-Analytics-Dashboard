```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
.env
.env.local
.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp

# IDE
.vscode/
.idea/

# Build artifacts
dist/
build/
target/

# Dependencies
node_modules/
.mypy_cache/
.pytest_cache/
.coverage
coverage/
htmlcov/
```